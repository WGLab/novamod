{
  "run": {
    "run_name": "online_test3"
  },
  "data": {
    "manifest_path": "data_manifest.csv",
    "sampling": {
      "kmer_len": 7,
      "normalize_signal": true
    }
  },
  "model": {
    "module": "models.model_v1_cnn_t",
    "kwargs": {
      "n_features": 11,
      "seq_len": 7,
      "d_model": 256,
      "cnn_channels": 128,
      "n_heads": 4,
      "n_layers": 3,
      "latent_dim": 16,
      "dropout": 0.0,
      "use_cls_token": true
    }
  },
  "train": {
    "recon": "nll",
    "huber_delta": 1.0,
    "nll_var": 1.0,
    "kmer_weight_center_base": 0.0,
    "kmer_weight_sd": 3.0
  },
  "val": {
    "checkpoint_epoch": 1,
    "output_dir": "validation",
    "loader": {
      "batch_size": 256,
      "num_workers": 10
    },
    "datasets": [
      {
        "name": "val",
        "data_id": "ecoli-nc",
        "method": "site",
        "spec": "/mnt/isilon/wang_lab/zac/software/reference/Ecoli_K12_MG1655_CpG-C.bed",
        "max_lines": 10000,
        "chromosome": null
      },
      {
        "name": "test",
        "data_id": "ecoli-mCpG",
        "method": "site",
        "spec": "/mnt/isilon/wang_lab/zac/software/reference/Ecoli_K12_MG1655_CpG-C.bed",
        "max_lines": 10000,
        "chromosome": null
      }
    ]
  }
}
